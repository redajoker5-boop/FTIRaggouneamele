// ---------- Helpers ----------
function buildPoints(spec, step = 2) {
  const pts = [];
  for (let i = 0; i < spec.x.length; i += step) {
    pts.push({ x: spec.x[i], y: spec.y[i] });
  }
  // ensure last point
  const last = spec.x.length - 1;
  if (pts[pts.length - 1].x !== spec.x[last]) {
    pts.push({ x: spec.x[last], y: spec.y[last] });
  }
  return pts;
}

function stat(spec) {
  let minY = Infinity, maxY = -Infinity, minX = 0, maxX = 0;
  for (let i = 0; i < spec.x.length; i++) {
    if (spec.y[i] < minY) { minY = spec.y[i]; minX = spec.x[i]; }
    if (spec.y[i] > maxY) { maxY = spec.y[i]; maxX = spec.x[i]; }
  }
  return { minY, maxY, minX, maxX };
}

function fmt(v, d = 2) {
  return Number(v).toFixed(d);
}

function injectStats(id, spec) {
  const s = stat(spec);
  document.getElementById(id).innerHTML = `
    <div class="stat"><span class="stat-label">T min %</span><span class="stat-val">${fmt(s.minY)}</span></div>
    <div class="stat"><span class="stat-label">à cm⁻¹</span><span class="stat-val">${fmt(s.minX, 0)}</span></div>
    <div class="stat"><span class="stat-label">T max %</span><span class="stat-val">${fmt(s.maxY)}</span></div>
    <div class="stat"><span class="stat-label">N pts</span><span class="stat-val">${spec.x.length}</span></div>
  `;
}

// ---------- Chart defaults ----------
Chart.defaults.font.family = "'JetBrains Mono', monospace";
Chart.defaults.font.size = 10;
Chart.defaults.color = '#8a93a3';

const baseScales = {
  x: {
    type: 'linear',
    reverse: true,           // FTIR convention : nombre d'onde décroissant
    title: { display: true, text: 'Nombre d\'onde (cm⁻¹)', color: '#8a93a3', font: { size: 11 } },
    grid: { color: 'rgba(42,49,61,0.5)' },
    ticks: { color: '#8a93a3' }
  },
  y: {
    title: { display: true, text: 'Transmittance (%)', color: '#8a93a3', font: { size: 11 } },
    grid: { color: 'rgba(42,49,61,0.5)' },
    ticks: { color: '#8a93a3' }
  }
};

const baseOpts = {
  responsive: true,
  maintainAspectRatio: false,
  animation: { duration: 600, easing: 'easeOutQuart' },
  interaction: { mode: 'nearest', axis: 'x', intersect: false },
  plugins: {
    legend: { display: false },
    tooltip: {
      backgroundColor: '#0e1014',
      borderColor: '#2a313d',
      borderWidth: 1,
      titleColor: '#d4a857',
      bodyColor: '#e8ecf2',
      padding: 10,
      callbacks: {
        title: (items) => items[0].parsed.x.toFixed(1) + ' cm⁻¹',
        label: (item) => item.dataset.label + ' : ' + item.parsed.y.toFixed(2) + ' %'
      }
    }
  },
  scales: baseScales,
  elements: { point: { radius: 0, hoverRadius: 4 }, line: { borderWidth: 1.4, tension: 0 } }
};

function singleChart(canvasId, spec, color, label) {
  return new Chart(document.getElementById(canvasId), {
    type: 'line',
    data: {
      datasets: [{
        label: label,
        data: buildPoints(spec, 2),
        borderColor: color,
        backgroundColor: color + '15',
        fill: true
      }]
    },
    options: baseOpts
  });
}

function compareChart(canvasId, specA, colorA, labelA, specB, colorB, labelB) {
  return new Chart(document.getElementById(canvasId), {
    type: 'line',
    data: {
      datasets: [
        {
          label: labelA,
          data: buildPoints(specA, 2),
          borderColor: colorA,
          backgroundColor: 'transparent',
          fill: false
        },
        {
          label: labelB,
          data: buildPoints(specB, 2),
          borderColor: colorB,
          backgroundColor: 'transparent',
          fill: false
        }
      ]
    },
    options: baseOpts
  });
}

// ---------- Build charts ----------
const css = getComputedStyle(document.documentElement);
const C1 = css.getPropertyValue('--c1').trim();
const C2 = css.getPropertyValue('--c2').trim();
const C3 = css.getPropertyValue('--c3').trim();

singleChart('ch1', SPECTRA.s1, C1, 'Spectre 1');
