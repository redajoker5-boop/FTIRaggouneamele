// ---------- Range buttons ----------
const RANGES = {
  full:   { min: 399,  max: 4000 },
  finger: { min: 400,  max: 1500 },
  mid:    { min: 1500, max: 2500 },
  oh:     { min: 2500, max: 4000 }
};

document.querySelectorAll('.btn').forEach(btn => {
  btn.addEventListener('click', () => {
    const target = btn.dataset.target;
    const range = btn.dataset.range;
    // toggle active among siblings
    document.querySelectorAll(`.btn[data-target="${target}"]`).forEach(b => b.classList.remove('active'));
    btn.classList.add('active');

    const chart = target === 'cmp13' ? chartCmp13 : chartCmp23;
    const r = RANGES[range];
    chart.options.scales.x.min = r.min;
    chart.options.scales.x.max = r.max;
    chart.update();
  });
});
